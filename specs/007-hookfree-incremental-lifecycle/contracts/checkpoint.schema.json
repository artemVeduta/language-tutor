{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/checkpoint.schema.json",
  "title": "Checkpoint",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "session_id", "modality", "step_kind", "state", "summary", "created_at"],
  "properties": {
    "id": { "type": "string", "pattern": "^ckpt_[A-Za-z0-9]+$" },
    "session_id": { "type": "string", "pattern": "^sess_[A-Za-z0-9]+$" },
    "modality": { "enum": ["lesson", "reading", "transcript", "vocab", "writing", "progress"] },
    "step_kind": { "enum": ["started", "prompt_shown", "feedback_shown", "progress_shown"] },
    "prompt_ref": { "type": ["string", "null"] },
    "state": {
      "type": "object",
      "title": "SafeStepState",
      "additionalProperties": false,
      "description": "Bounded safe step metadata only; no raw secrets, full host logs, full transcripts, or local config.",
      "properties": {
        "prompt_ref": { "type": ["string", "null"] },
        "step_index": { "type": ["integer", "null"], "minimum": 0 },
        "total_steps": { "type": ["integer", "null"], "minimum": 0 },
        "modality_hint": { "type": ["string", "null"] },
        "labels": { "type": "array", "items": { "type": "string" }, "maxItems": 16 }
      }
    },
    "summary": { "type": "string", "maxLength": 280 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
