{
  "$defs": {
    "ReviewIntensity": {
      "enum": [
        "light",
        "normal",
        "heavy"
      ],
      "title": "ReviewIntensity",
      "type": "string"
    },
    "SelectionPolicy": {
      "additionalProperties": false,
      "properties": {
        "due_first": {
          "default": true,
          "title": "Due First",
          "type": "boolean"
        },
        "intensity": {
          "$ref": "#/$defs/ReviewIntensity",
          "default": "normal"
        },
        "recent_session_limit": {
          "default": 10,
          "title": "Recent Session Limit",
          "type": "integer"
        },
        "reserved_non_weak_due_slot": {
          "default": false,
          "title": "Reserved Non Weak Due Slot",
          "type": "boolean"
        },
        "weak_tag_limit": {
          "default": 5,
          "title": "Weak Tag Limit",
          "type": "integer"
        }
      },
      "title": "SelectionPolicy",
      "type": "object"
    },
    "SelectionReason": {
      "additionalProperties": false,
      "properties": {
        "bucket": {
          "enum": [
            "overdue_due",
            "due_today",
            "new_fill"
          ],
          "title": "Bucket",
          "type": "string"
        },
        "due_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Due At"
        },
        "item_id": {
          "title": "Item Id",
          "type": "string"
        },
        "matched_weak_tags": {
          "items": {
            "type": "string"
          },
          "title": "Matched Weak Tags",
          "type": "array"
        },
        "rank": {
          "minimum": 1,
          "title": "Rank",
          "type": "integer"
        },
        "reasons": {
          "items": {
            "enum": [
              "overdue",
              "due",
              "weak_tag_match",
              "explicit_filter_match",
              "reserved_non_weak_due",
              "new_card_fill"
            ],
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        }
      },
      "required": [
        "item_id",
        "rank",
        "bucket",
        "reasons"
      ],
      "title": "SelectionReason",
      "type": "object"
    },
    "VocabularyItem": {
      "additionalProperties": false,
      "properties": {
        "accepted_answers": {
          "items": {
            "type": "string"
          },
          "title": "Accepted Answers",
          "type": "array"
        },
        "card_type": {
          "default": "standard",
          "enum": [
            "standard",
            "cloze"
          ],
          "title": "Card Type",
          "type": "string"
        },
        "hint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hint"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "lemma": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lemma"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        },
        "prompt": {
          "title": "Prompt",
          "type": "string"
        },
        "sources": {
          "items": {
            "type": "string"
          },
          "title": "Sources",
          "type": "array"
        },
        "state": {
          "$ref": "#/$defs/VocabularyItemState"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        },
        "target_language": {
          "title": "Target Language",
          "type": "string"
        }
      },
      "required": [
        "id",
        "target_language",
        "prompt",
        "accepted_answers"
      ],
      "title": "VocabularyItem",
      "type": "object"
    },
    "VocabularyItemState": {
      "additionalProperties": false,
      "properties": {
        "due_at": {
          "format": "date-time",
          "title": "Due At",
          "type": "string"
        },
        "ease_factor": {
          "default": 2.5,
          "minimum": 1.3,
          "title": "Ease Factor",
          "type": "number"
        },
        "interval_days": {
          "default": 0,
          "minimum": 0,
          "title": "Interval Days",
          "type": "integer"
        },
        "repetition_count": {
          "default": 0,
          "minimum": 0,
          "title": "Repetition Count",
          "type": "integer"
        },
        "state": {
          "default": "new",
          "enum": [
            "new",
            "learning",
            "review",
            "mature",
            "relearning"
          ],
          "title": "State",
          "type": "string"
        }
      },
      "title": "VocabularyItemState",
      "type": "object"
    },
    "WeakTagSignal": {
      "additionalProperties": false,
      "properties": {
        "latest_seen_at": {
          "format": "date-time",
          "title": "Latest Seen At",
          "type": "string"
        },
        "priority_rank": {
          "minimum": 1,
          "title": "Priority Rank",
          "type": "integer"
        },
        "session_count": {
          "minimum": 2,
          "title": "Session Count",
          "type": "integer"
        },
        "source_counts": {
          "$ref": "#/$defs/WeakTagSourceCounts"
        },
        "tag": {
          "title": "Tag",
          "type": "string"
        }
      },
      "required": [
        "tag",
        "session_count",
        "latest_seen_at",
        "priority_rank"
      ],
      "title": "WeakTagSignal",
      "type": "object"
    },
    "WeakTagSourceCounts": {
      "additionalProperties": false,
      "properties": {
        "low_quality_reviews": {
          "default": 0,
          "minimum": 0,
          "title": "Low Quality Reviews",
          "type": "integer"
        },
        "mistake_events": {
          "default": 0,
          "minimum": 0,
          "title": "Mistake Events",
          "type": "integer"
        }
      },
      "title": "WeakTagSourceCounts",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "active_weak_tags": {
      "items": {
        "$ref": "#/$defs/WeakTagSignal"
      },
      "title": "Active Weak Tags",
      "type": "array"
    },
    "due_matching_count": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Due Matching Count"
    },
    "effective_count": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Effective Count"
    },
    "empty_reason": {
      "anyOf": [
        {
          "enum": [
            "no_matching_cards",
            "matching_cards_not_due"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Empty Reason"
    },
    "filter": {
      "items": {
        "type": "string"
      },
      "title": "Filter",
      "type": "array"
    },
    "items": {
      "items": {
        "$ref": "#/$defs/VocabularyItem"
      },
      "title": "Items",
      "type": "array"
    },
    "matching_count": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Matching Count"
    },
    "requested_count": {
      "title": "Requested Count",
      "type": "integer"
    },
    "selection_policy": {
      "$ref": "#/$defs/SelectionPolicy"
    },
    "selection_reasons": {
      "items": {
        "$ref": "#/$defs/SelectionReason"
      },
      "title": "Selection Reasons",
      "type": "array"
    },
    "starter_content_required": {
      "default": false,
      "title": "Starter Content Required",
      "type": "boolean"
    }
  },
  "required": [
    "items",
    "requested_count"
  ],
  "title": "VocabularySessionPlan",
  "type": "object"
}